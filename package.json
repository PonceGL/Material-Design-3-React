{
  "name": "material-design-3-react",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm --filter @poncegl/material-design-3 build",
    "build:local": "pnpm --filter @poncegl/material-design-3 build:local",
    "dev": "pnpm --filter example dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "pnpm --filter example preview",
    "test": "pnpm --filter @poncegl/material-design-3 test",
    "test:coverage": "pnpm --filter @poncegl/material-design-3 test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.28.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
