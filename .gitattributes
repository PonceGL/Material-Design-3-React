# Enforce LF line endings for all text files on all platforms.
# This prevents Git from converting LF to CRLF on Windows checkout,
# which would cause Prettier to mark every file as needing formatting.
* text=auto eol=lf

# Windows-only scripts that require CRLF to execute correctly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
